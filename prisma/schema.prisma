generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  password         String?
  role             Role      @default(GUEST)
  avatar           String?
  bio              String?
  createdAt        DateTime  @default(now())
  resetToken       String?
  resetTokenExpiry DateTime?

  listings  Listing[]
  bookings  Booking[]
  reviews   Review[]

  @@index([name])
  @@index([role])
}

model Listing {
  id            String      @id @default(uuid())
  title         String
  description   String?
  pricePerNight Float
  guest         Int
  location      String
  type          ListingType
  amenities     String[]
  rating        Float?
  hostId        String
  host          User        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookings Booking[]
  photos   ListingPhoto[]
  reviews  Review[]

  @@index([hostId])
  @@index([location])
  @@index([type])
  @@index([pricePerNight])
}

model Booking {
  id         String        @id @default(uuid())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  guests     Int           @default(1)
  status     BookingStatus @default(PENDING)
  listingId  String
  guestId    String
  createdAt  DateTime      @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guest   User    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([listingId])
}

model ListingPhoto {
  id        String  @id @default(uuid())
  url       String
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  GUEST
  HOST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
